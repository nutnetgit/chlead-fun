# Ch.Lead FUN — Settings app
# DB user n8n_fun has rights ONLY to the dedicated ch_lead_fun database
# (created by sql/001_fun_schema.sql). Password Er@w@n12345 → URL-encode @ as %40.
# Dev (from LAN; mariadb-erawan is exposed on host port 3308):
DATABASE_URL="mysql://n8n_fun:Er%40w%40n12345@192.168.0.10:3308/ch_lead_fun"
# On the NAS (inside docker, on hermes-net with mariadb-erawan):
# DATABASE_URL="mysql://n8n_fun:Er%40w%40n12345@mariadb-erawan:3306/ch_lead_fun"

# Shared secret for server-to-server webhook calls (n8n → app), same pattern as CATS.
WEBHOOK_SECRET="CHANGE_ME"

# Facebook Lead Ads intake — the app handles the Meta webhook directly (Phase 2).
META_VERIFY_TOKEN="pick-any-random-string"   # you choose; used when subscribing the webhook in Meta
META_APP_SECRET="CHANGE_ME"                  # Meta App → Settings → Basic → App Secret
FB_SYSTEM_USER_TOKEN="CHANGE_ME"             # System User token n8n-lead-bot (never expires)
LINE_CHANNEL_ACCESS_TOKEN="CHANGE_ME"        # CEA Sales Assistant OA — for pushing the lead card

# Gemini — FUN's OWN key/project (not shared with Nong Count). WF2 scoring + WF3 drafts.
GEMINI_API_KEY="CHANGE_ME"
GEMINI_MODEL="gemini-3.1-flash-lite"

# LIFF app under the CEA Sales Assistant Messaging API channel — links a QR
# lead to the customer's verified LINE userId once they add/open the OA
# (user req 2026-07-08). Endpoint URL: https://fun.ch-erawan.com/liff/welcome,
# Scope: profile, Bot link feature: On (Aggressive). MUST be passed as a
# docker build --build-arg (NEXT_PUBLIC_* is inlined at build time, see Dockerfile).
NEXT_PUBLIC_LIFF_ID=""

# Canonical public domain baked into customer-facing QR links (lead-form URL).
# MUST NOT be window.location.origin at runtime — a customer scans this on
# their own phone/cellular data and can't reach an internal LAN/tunnel address
# staff might be viewing the app from. Defaults to the production domain in
# the Dockerfile; only override via --build-arg for a staging deploy.
NEXT_PUBLIC_APP_URL="https://fun.ch-erawan.com"
